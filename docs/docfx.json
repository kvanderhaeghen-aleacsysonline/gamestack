{
  "metadata": [
    {
      "src": [
        {
          "files": [ "src/**/*.csproj" ],
          "src": ".."
        }
      ],
      "dest": "api",
      "properties": { "TargetFramework": "net10.0" }
    }
  ],
  "build": {
    "content": [
      { "files": [ "api/**.yml", "api/index.md" ] },
      { "files": [ "articles/**.md", "articles/**/toc.yml", "toc.yml", "*.md" ] }
    ],
    "resource": [
      { "files": [ "images/**" ] }
    ],
    "output": "_site",
    "template": [ "default", "modern" ],
    "globalMetadata": {
      "_appName": "Gamestack",
      "_appTitle": "Gamestack — source control for artists",
      "_enableSearch": true,
      "pdf": false
    }
  }
}
