<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Gamestack.App.Views.PromptDialog"
        Title="Gamestack" Width="400" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" Spacing="12">
        <TextBlock x:Name="TitleText" FontWeight="Bold" FontSize="15"/>
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" Opacity="0.9"/>
        <TextBox x:Name="Input"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Click="OnCancel" MinWidth="80"/>
            <Button Content="OK" Click="OnOk" MinWidth="80" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
