<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gamestack.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="830" d:DesignHeight="600"
             x:Class="Gamestack.App.Views.GamesView"
             x:DataType="vm:GamesViewModel">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
            <TextBlock Text="Game links" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="➕ Add game" Command="{Binding AddGameCommand}"/>
            <Button Content="↻ Refresh" Command="{Binding RefreshCommand}"/>
            <Button Content="Create missing" Command="{Binding CreateMissingCommand}"/>
            <Button Content="💾 Save" Command="{Binding SaveCommand}"/>
        </StackPanel>
        <TextBlock DockPanel.Dock="Top" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,8"
                   Text="Each top-level folder in your synced folder is linked to a game via a gamestack.json file. The gameId defaults to the folder name and is editable here."/>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Opacity="0.7" Margin="0,8,0,0"/>

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Projects}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:GameLinkItemViewModel">
                        <Grid ColumnDefinitions="*,2*,Auto" Margin="0,3">
                            <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding GameId}" PlaceholderText="gameId" Margin="8,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding MarkerLabel}"
                                       VerticalAlignment="Center" Opacity="0.5" FontSize="11"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
